# TransPulse Environment Variables Configuration

# Secret key for encrypting sessions. Use a strong, random value in production.
SECRET_KEY=your_secret_key_here

# Database connection string (defaults to SQLite if not provided)
# Example for PostgreSQL: postgresql://username:password@localhost/dbname
DATABASE_URL=sqlite:///instance/transpulse.db

# Flask environment: 'development' or 'production'
FLASK_ENV=development

# Stop radius in kilometers for bus tracking (default: 0.03)
STOP_RADIUS_KM=0.03

# URI for storing rate limiting data (default: memory://)
RATELIMIT_STORAGE_URI=memory://

# Google OAuth Client ID for authentication
GOOGLE_CLIENT_ID=your_google_client_id_here

# Session lifetime in hours (default: 8)
SESSION_LIFETIME_HOURS=8

# CSRF token time limit in seconds (default: 3600)
WTF_CSRF_TIME_LIMIT=3600
